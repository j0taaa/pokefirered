{
  "name": "pokefirered-ts-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "api:build": "vite build --ssr src/api/textApiServer.ts --outDir dist-api --emptyOutDir",
    "api:start": "node dist-api/textApiServer.js --host 127.0.0.1",
    "test:api": "vitest run test/textApiServer.test.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
